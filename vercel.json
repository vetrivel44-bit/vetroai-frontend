{
  "version": 3,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "^/(chat|generate-title|follow-ups|health)$", "dest": "/backend/api/index.js" },
    { "src": "^/(.*)$", "dest": "/frontend/$1" }
  ]
}
