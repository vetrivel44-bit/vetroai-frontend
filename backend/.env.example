PORT=3000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/vetroai
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1400
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-1
MISTRAL_TEMPERATURE=0.7
MISTRAL_MAX_TOKENS=8192
# RapidAPI key shared by the ChatGPT provider, Vision API, AI Doctor API, and TTS proxy
CHATGPT_API_KEY=your_rapidapi_key_here
ENABLE_CLOUD_SESSIONS=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=whatsapp:+14155238886
BOOKING_NOTIFICATION_PHONES=8778508652,9994777865

# ── Persistent accounts (required for billing/credits to survive a restart) ──
# Leave unset to keep running in offline/in-memory auth mode.
MONGO_URI=

# Used to build Stripe success/cancel/portal redirect URLs.
FRONTEND_URL=http://localhost:5174

# ── Stripe billing (leave unset to keep "Upgrade plan" UI visible but disabled) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
